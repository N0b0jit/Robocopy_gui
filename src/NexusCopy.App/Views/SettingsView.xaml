<UserControl x:Class="NexusCopy.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Typography.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            
            <!-- Appearance -->
            <GroupBox Header="Appearance" Margin="0,0,0,16">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <CheckBox Grid.Row="0"
                              Content="Use Dark Theme"
                              IsChecked="{Binding DarkTheme}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="2"
                              Content="Minimize to System Tray"
                              IsChecked="{Binding MinimizeToTray}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                </Grid>
            </GroupBox>
            
            <!-- Behavior -->
            <GroupBox Header="Behavior" Margin="0,0,0,16">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <CheckBox Grid.Row="0"
                              Content="Auto-start copy when paths are valid"
                              IsChecked="{Binding AutoStartCopy}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="2"
                              Content="Confirm before cancelling operation"
                              IsChecked="{Binding ConfirmBeforeCancel}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="4"
                              Content="Show notification when copy completes"
                              IsChecked="{Binding ShowNotifications}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="6"
                              Content="Auto-save profiles when creating new ones"
                              IsChecked="{Binding AutoSaveProfiles}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                </Grid>
            </GroupBox>
            
            <!-- Default Options -->
            <GroupBox Header="Default Copy Options" Margin="0,0,0,16">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <CheckBox Grid.Row="0" Grid.Column="0"
                              Content="Include Subdirectories"
                              IsChecked="{Binding IncludeSubdirsDefault}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="0" Grid.Column="1"
                              Content="Restartable Mode"
                              IsChecked="{Binding RestartableModeDefault}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Default Thread Count:"
                               Style="{StaticResource NexusBodyStyle}"
                               VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <Slider Value="{Binding DefaultThreadCount}"
                                Minimum="1"
                                Maximum="128"
                                Width="120"
                                Style="{StaticResource NexusSliderStyle}"/>
                        <TextBlock Text="{Binding DefaultThreadCount}"
                                   Style="{StaticResource NexusBodyStyle}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   MinWidth="30"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="Default Exclude Files:"
                               Style="{StaticResource NexusBodyStyle}"
                               VerticalAlignment="Center"/>
                    
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding DefaultExcludeFiles}"
                             Style="{StaticResource NexusTextBoxStyle}"
                             FontSize="10"/>
                    
                    <TextBlock Grid.Row="6" Grid.Column="0"
                               Text="Default Exclude Dirs:"
                               Style="{StaticResource NexusBodyStyle}"
                               VerticalAlignment="Center"/>
                    
                    <TextBox Grid.Row="6" Grid.Column="1"
                             Text="{Binding DefaultExcludeDirectories}"
                             Style="{StaticResource NexusTextBoxStyle}"
                             FontSize="10"/>
                    
                    <TextBlock Grid.Row="8" Grid.Column="0"
                               Text="Max History Items:"
                               Style="{StaticResource NexusBodyStyle}"
                               VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                        <Slider Value="{Binding MaxHistoryItems}"
                                Minimum="10"
                                Maximum="500"
                                Width="120"
                                Style="{StaticResource NexusSliderStyle}"/>
                        <TextBlock Text="{Binding MaxHistoryItems}"
                                   Style="{StaticResource NexusBodyStyle}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   MinWidth="30"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
            
            <!-- Data Management -->
            <GroupBox Header="Data Management" Margin="0,0,0,16">
                <StackPanel Margin="8">
                    <Button Content="📁 Open Data Folder"
                            Command="{Binding OpenDataFolderCommand}"
                            Style="{StaticResource NexusSecondaryButtonStyle}"
                            Padding="12,6"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"/>
                    
                    <TextBlock Text="The data folder contains profiles, history, logs, and settings."
                               Style="{StaticResource NexusBodyStyle}"
                               Foreground="{DynamicResource NexusTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>
            
            <!-- About -->
            <GroupBox Header="About" Margin="0,0,0,16">
                <StackPanel Margin="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nexus Copy"
                                       Style="{StaticResource NexusTitleStyle}"
                                       FontSize="16"/>
                            <TextBlock Text="{Binding AppVersion}"
                                       Style="{StaticResource NexusBodyStyle}"
                                       Foreground="{DynamicResource NexusTextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="Fast. Powerful. Simple. File copying reimagined."
                                       Style="{StaticResource NexusBodyStyle}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="Built with C# 12 / .NET 8 / WPF"
                                       Style="{StaticResource NexusBodyStyle}"
                                       FontSize="10"
                                       Foreground="{DynamicResource NexusTextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="© 2026 Nexus Copy"
                                       Style="{StaticResource NexusBodyStyle}"
                                       FontSize="10"
                                       Foreground="{DynamicResource NexusTextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1"
                                Content="About"
                                Command="{Binding ShowAboutCommand}"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Padding="16,6"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
            
            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset to Defaults"
                        Command="{Binding ResetToDefaultsCommand}"
                        Style="{StaticResource NexusSecondaryButtonStyle}"
                        Padding="16,6"
                        Margin="0,0,8,0"
                        Background="{StaticResource NexusWarningBrush}"
                        BorderBrush="{StaticResource NexusWarningBrush}"
                        Foreground="White"/>
                
                <Button Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        Style="{StaticResource NexusButtonStyle}"
                        Padding="16,6"/>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
