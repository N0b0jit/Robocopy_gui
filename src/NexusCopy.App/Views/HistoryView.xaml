<UserControl x:Class="NexusCopy.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Typography.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header and Search -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource NexusTextBoxStyle}"
                     Width="300"
                     HorizontalAlignment="Left"
                     Margin="0,0,16,0"/>
            
            <Button Grid.Column="1"
                    Content="🔄 Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource NexusSecondaryButtonStyle}"
                    Padding="12,6"
                    Margin="0,0,8,0"/>
            
            <Button Grid.Column="2"
                    Content="🗑️ Clear"
                    Command="{Binding ClearHistoryCommand}"
                    Style="{StaticResource NexusSecondaryButtonStyle}"
                    Padding="12,6"
                    Margin="0,0,8,0"/>
            
            <Button Grid.Column="3"
                    Content="📄 Open Log"
                    Command="{Binding OpenLogFileCommand}"
                    Style="{StaticResource NexusSecondaryButtonStyle}"
                    Padding="12,6"/>
        </Grid>
        
        <!-- Status Message -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource NexusBodyStyle}"
                   Foreground="{StaticResource NexusAccentBrush}"/>
        
        <!-- Job List -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource NexusBorderBrush}"
                  Background="{DynamicResource NexusSurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource NexusBackgroundBrush}">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" 
                                    Binding="{Binding StartedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                    Width="140"
                                    IsReadOnly="True"/>
                
                <DataGridTextColumn Header="Status" 
                                    Binding="{Binding Status}"
                                    Width="80"
                                    IsReadOnly="True"/>
                
                <DataGridTextColumn Header="Mode" 
                                    Binding="{Binding Options.Mode}"
                                    Width="60"
                                    IsReadOnly="True"/>
                
                <DataGridTextColumn Header="Source" 
                                    Binding="{Binding Options.Source}"
                                    Width="200"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn Header="Destination" 
                                    Binding="{Binding Options.Destination}"
                                    Width="200"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                
                <DataGridTextColumn Header="Files" 
                                    Binding="{Binding Progress.FilesCopied, StringFormat=N0}"
                                    Width="80"
                                    IsReadOnly="True"/>
                
                <DataGridTextColumn Header="Size" 
                                    Binding="{Binding Progress.BytesCopied, Converter={StaticResource SizeConverter}}"
                                    Width="80"
                                    IsReadOnly="True"/>
                
                <DataGridTextColumn Header="Duration" 
                                    Binding="{Binding CompletedAt, Converter={StaticResource DurationConverter}}"
                                    Width="80"
                                    IsReadOnly="True"/>
                
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="📋"
                                        ToolTip="Copy command"
                                        Command="{Binding DataContext.CopyCommandToClipboardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Style="{StaticResource NexusSecondaryButtonStyle}"
                                        Width="24"
                                        Height="20"
                                        FontSize="10"
                                        Margin="0,0,4,0"/>
                                <Button Content="📄"
                                        ToolTip="Open log file"
                                        Command="{Binding DataContext.OpenLogFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Style="{StaticResource NexusSecondaryButtonStyle}"
                                        Width="24"
                                        Height="20"
                                        FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Loading Overlay -->
        <Grid Grid.Row="4" 
              Background="{DynamicResource NexusBackgroundBrush}"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="20"
                             Style="{StaticResource NexusProgressBarStyle}"/>
                <TextBlock Text="Loading..." 
                           Style="{StaticResource NexusBodyStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
        
    </Grid>
</UserControl>
