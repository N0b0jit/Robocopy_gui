<UserControl x:Class="NexusCopy.App.Views.ProfileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Typography.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Profile List -->
        <GroupBox Grid.Column="0" Header="Saved Profiles">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- List Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Button Content="➕ New"
                            Command="{Binding NewProfileCommand}"
                            Style="{StaticResource NexusButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="📥 Import"
                            Command="{Binding ImportProfileCommand}"
                            Style="{StaticResource NexusSecondaryButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="📤 Export"
                            Command="{Binding ExportProfileCommand}"
                            Style="{StaticResource NexusSecondaryButtonStyle}"
                            Padding="12,6"/>
                </StackPanel>
                
                <!-- Profile List -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="{DynamicResource NexusSurfaceBrush}"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource NexusBorderBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="2">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource NexusHeaderStyle}"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource NexusBodyStyle}"
                                               Foreground="{DynamicResource NexusTextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='Created: {0:yyyy-MM-dd HH:mm}'}"
                                               Style="{StaticResource NexusBodyStyle}"
                                               FontSize="10"
                                               Foreground="{DynamicResource NexusTextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Loading Overlay -->
                <Grid Grid.Row="2" 
                      Background="{DynamicResource NexusBackgroundBrush}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" 
                                     Width="200" 
                                     Height="20"/>
                        <TextBlock Text="Loading..." 
                                   Style="{StaticResource NexusBodyStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>
        
        <!-- Profile Editor -->
        <GroupBox Grid.Column="2" Header="Profile Editor">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Profile Info -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBox Grid.Row="0"
                             Text="{Binding ProfileName}"
                             Style="{StaticResource NexusTextBoxStyle}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Margin="0,0,0,8"/>
                    
                    <TextBox Grid.Row="2"
                             Text="{Binding ProfileDescription}"
                             Style="{StaticResource NexusTextBoxStyle}"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
                
                <!-- Copy Options -->
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <ContentControl DataContext="{Binding OptionsViewModel}">
                        <StackPanel>
                            <!-- Mode -->
                            <GroupBox Header="Mode" Margin="0,0,0,8">
                                <StackPanel Margin="8" Orientation="Horizontal">
                                    <RadioButton Content="Copy" 
                                                 IsChecked="{Binding Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Copy}"
                                                 Margin="0,0,16,0"/>
                                    <RadioButton Content="Move" 
                                                 IsChecked="{Binding Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Move}"
                                                 Margin="0,0,16,0"/>
                                    <RadioButton Content="Mirror" 
                                                 IsChecked="{Binding Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Mirror}"
                                                 Margin="0,0,16,0"/>
                                    <RadioButton Content="Sync" 
                                                 IsChecked="{Binding Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Sync}"/>
                                </StackPanel>
                            </GroupBox>
                            
                            <!-- Basic Options -->
                            <GroupBox Header="Basic Options" Margin="0,0,0,8">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Row="0" Grid.Column="0"
                                              Content="Include Subdirectories"
                                              IsChecked="{Binding IncludeSubdirectories}"
                                              Style="{StaticResource NexusCheckBoxStyle}"/>
                                    
                                    <CheckBox Grid.Row="0" Grid.Column="1"
                                              Content="Restartable Mode"
                                              IsChecked="{Binding RestartableMode}"
                                              Style="{StaticResource NexusCheckBoxStyle}"/>
                                    
                                    <CheckBox Grid.Row="2" Grid.Column="0"
                                              Content="Multi-Threaded"
                                              IsChecked="{Binding MultiThreaded}"
                                              Style="{StaticResource NexusCheckBoxStyle}"/>
                                    
                                    <CheckBox Grid.Row="2" Grid.Column="1"
                                              Content="Backup Mode"
                                              IsChecked="{Binding BackupMode}"
                                              Style="{StaticResource NexusCheckBoxStyle}"/>
                                    
                                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                        <TextBlock Text="Threads:" 
                                                   Style="{StaticResource NexusBodyStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <Slider Value="{Binding ThreadCount}"
                                                Minimum="1"
                                                Maximum="128"
                                                Width="120"
                                                Style="{StaticResource NexusSliderStyle}"/>
                                        <TextBlock Text="{Binding ThreadCount}"
                                                   Style="{StaticResource NexusBodyStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   MinWidth="30"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                            
                            <!-- Advanced Options -->
                            <GroupBox Header="Advanced Options" Margin="0,0,0,8">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Row="0" Grid.Column="0"
                                              Content="Skip Newer Files"
                                              IsChecked="{Binding SkipNewerFiles}"
                                              Style="{StaticResource NexusCheckBoxStyle}"/>
                                    
                                    <CheckBox Grid.Row="0" Grid.Column="1"
                                              Content="Exclude Hidden"
                                              IsChecked="{Binding ExcludeHidden}"
                                              Style="{StaticResource NexusCheckBoxStyle}"/>
                                    
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Exclude Files:"
                                               Style="{StaticResource NexusBodyStyle}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding ExcludeFiles}"
                                             Style="{StaticResource NexusTextBoxStyle}"
                                             FontSize="10"/>
                                    
                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Exclude Dirs:"
                                               Style="{StaticResource NexusBodyStyle}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBox Grid.Row="4" Grid.Column="1"
                                             Text="{Binding ExcludeDirectories}"
                                             Style="{StaticResource NexusTextBoxStyle}"
                                             FontSize="10"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ContentControl>
                </ScrollViewer>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelEditCommand}"
                            Style="{StaticResource NexusSecondaryButtonStyle}"
                            Padding="16,6"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    
                    <Button Content="Delete"
                            Command="{Binding DeleteProfileCommand}"
                            Style="{StaticResource NexusSecondaryButtonStyle}"
                            Padding="16,6"
                            Margin="0,0,8,0"
                            Background="{StaticResource NexusErrorBrush}"
                            BorderBrush="{StaticResource NexusErrorBrush}"
                            Foreground="White"/>
                    
                    <Button Content="Save"
                            Command="{Binding SaveProfileCommand}"
                            Style="{StaticResource NexusButtonStyle}"
                            Padding="16,6"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
