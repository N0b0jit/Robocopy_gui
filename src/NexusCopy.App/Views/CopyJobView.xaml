<UserControl x:Class="NexusCopy.App.Views.CopyJobView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:NexusCopy.App.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Typography.xaml"/>
                <ResourceDictionary Source="/Styles/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            
            <!-- Source and Destination -->
            <GroupBox Header="Folders" Margin="0,0,0,16">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Source -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0"
                                   Text="SOURCE:"
                                   Style="{StaticResource NexusHeaderStyle}"
                                   VerticalAlignment="Center"/>
                        
                        <controls:FolderPickerControl Grid.Column="1"
                                                    Path="{Binding CopyJobVm.SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                                    Placeholder="Select source folder"/>
                    </Grid>
                    
                    <!-- Destination -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0"
                                   Text="DESTINATION:"
                                   Style="{StaticResource NexusHeaderStyle}"
                                   VerticalAlignment="Center"/>
                        
                        <controls:FolderPickerControl Grid.Column="1"
                                                    Path="{Binding CopyJobVm.DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                                    Placeholder="Select destination folder"/>
                    </Grid>
                </Grid>
            </GroupBox>
            
            <!-- Mode Selection -->
            <GroupBox Header="Mode" Margin="0,0,0,16">
                <StackPanel Margin="8" Orientation="Horizontal">
                    <RadioButton Content="Copy" 
                                 IsChecked="{Binding CopyJobVm.OptionsViewModel.Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Copy}"
                                 Margin="0,0,16,0"/>
                    <RadioButton Content="Move" 
                                 IsChecked="{Binding CopyJobVm.OptionsViewModel.Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Move}"
                                 Margin="0,0,16,0"/>
                    <RadioButton Content="Mirror" 
                                 IsChecked="{Binding CopyJobVm.OptionsViewModel.Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Mirror}"
                                 Margin="0,0,16,0"/>
                    <RadioButton Content="Sync" 
                                 IsChecked="{Binding CopyJobVm.OptionsViewModel.Mode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Sync}"/>
                </StackPanel>
            </GroupBox>
            
            <!-- Options -->
            <GroupBox Header="Options" Margin="0,0,0,16">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Row 1 -->
                    <CheckBox Grid.Row="0" Grid.Column="0"
                              Content="Include Subdirectories"
                              IsChecked="{Binding CopyJobVm.OptionsViewModel.IncludeSubdirectories}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="0" Grid.Column="1"
                              Content="Restartable Mode"
                              IsChecked="{Binding CopyJobVm.OptionsViewModel.RestartableMode}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="0" Grid.Column="2"
                              Content="Multi-Threaded"
                              IsChecked="{Binding CopyJobVm.OptionsViewModel.MultiThreaded}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <!-- Row 2 -->
                    <CheckBox Grid.Row="2" Grid.Column="0"
                              Content="Backup Mode"
                              IsChecked="{Binding CopyJobVm.OptionsViewModel.BackupMode}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="2" Grid.Column="1"
                              Content="Skip Newer Files"
                              IsChecked="{Binding CopyJobVm.OptionsViewModel.SkipNewerFiles}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <CheckBox Grid.Row="2" Grid.Column="2"
                              Content="Exclude Hidden Files"
                              IsChecked="{Binding CopyJobVm.OptionsViewModel.ExcludeHidden}"
                              Style="{StaticResource NexusCheckBoxStyle}"/>
                    
                    <!-- Thread Count -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <TextBlock Text="Threads:" 
                                   Style="{StaticResource NexusBodyStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Slider Value="{Binding CopyJobVm.OptionsViewModel.ThreadCount}"
                                Minimum="1"
                                Maximum="128"
                                Width="200"
                                Style="{StaticResource NexusSliderStyle}"/>
                        <TextBlock Text="{Binding CopyJobVm.OptionsViewModel.ThreadCount}"
                                   Style="{StaticResource NexusBodyStyle}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   MinWidth="30"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
            
            <!-- Command Preview -->
            <controls:CommandPreviewControl Grid.Row="0"
                                            CommandPreview="{Binding CopyJobVm.CommandPreview}"
                                            Margin="0,0,0,16"/>
            
            <!-- Control Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="▶ Start"
                        Command="{Binding CopyJobVm.StartCopyCommand}"
                        Style="{StaticResource NexusButtonStyle}"
                        Padding="20,8"
                        Margin="0,0,8,0"/>
                
                <Button Content="⏸ Pause"
                        Command="{Binding CopyJobVm.PauseCopyCommand}"
                        Style="{StaticResource NexusSecondaryButtonStyle}"
                        Padding="16,8"
                        Margin="0,0,8,0"/>
                
                <Button Content="⏹ Cancel"
                        Command="{Binding CopyJobVm.CancelCopyCommand}"
                        Style="{StaticResource NexusSecondaryButtonStyle}"
                        Padding="16,8"
                        Margin="0,0,8,0"/>
                
                <Button Content="💾 Save Profile"
                        Command="{Binding CopyJobVm.SaveProfileCommand}"
                        Style="{StaticResource NexusSecondaryButtonStyle}"
                        Padding="16,8"/>
            </StackPanel>
            
            <!-- Progress Panel -->
            <controls:ProgressPanelControl Grid.Row="0"
                                            DataContext="{Binding CopyJobVm.ProgressViewModel}"
                                            Margin="0,0,0,16"/>
            
            <!-- Log Viewer -->
            <controls:LogViewerControl Grid.Row="0"
                                       LogOutput="{Binding CopyJobVm.LogOutput}"
                                       AutoScroll="{Binding CopyJobVm.AutoScrollLog}"
                                       Height="200"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
