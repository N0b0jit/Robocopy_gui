<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Font Families -->
    <FontFamily x:Key="NexusFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="NexusMonospaceFontFamily">Consolas, Courier New</FontFamily>
    
    <!-- Typography Styles -->
    <Style x:Key="NexusTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusFontFamily}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource NexusTextPrimaryBrush}"/>
    </Style>
    
    <Style x:Key="NexusHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusFontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource NexusTextPrimaryBrush}"/>
    </Style>
    
    <Style x:Key="NexusBodyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusFontFamily}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource NexusTextPrimaryBrush}"/>
    </Style>
    
    <Style x:Key="NexusLogStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource NexusMonospaceFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource NexusTextPrimaryBrush}"/>
    </Style>

</ResourceDictionary>
