<UserControl x:Class="NexusCopy.App.Controls.FolderPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="400">
    
    <UserControl.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource NexusTextBoxStyle}"/>
        <Style TargetType="Button" BasedOn="{StaticResource NexusSecondaryButtonStyle}"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        
        <TextBox x:Name="PathTextBox"
                 Grid.Column="0"
                 Text="{Binding Path, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                 IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 AllowDrop="True"
                 Drop="PathTextBox_Drop"
                 DragEnter="PathTextBox_DragEnter"
                 DragLeave="PathTextBox_DragLeave"
                 Margin="0,0,8,0"/>
        
        <Button x:Name="BrowseButton"
                Grid.Column="1"
                Content="Browse"
                Click="BrowseButton_Click"
                Padding="12,6"
                Margin="0,0,8,0"/>
        
        <Button x:Name="FolderButton"
                Grid.Column="2"
                Content="📂"
                FontSize="16"
                Width="36"
                Height="32"
                Click="BrowseButton_Click"/>
    </Grid>
</UserControl>
